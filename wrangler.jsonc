{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "personal-wealth-management",
  "main": "src/worker/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "pwm_db",
      "database_id": "d09e0fa3-369e-4ff7-820d-34edc968e93e"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "PRICE_CACHE",
      "id": "0f994a5e772446369d7f51ce9b8fdac0"
    }
  ],
  "triggers": {
    "crons": ["0 5 * * *"]
  },
  "vars": {
    "DEFAULT_CURRENCY": "USD"
  }
  // Secrets (set via `wrangler secret put <NAME>`):
  //   FINNHUB_API_KEY        – https://finnhub.io (free)
  //   COINGECKO_DEMO_API_KEY – https://www.coingecko.com/en/api/pricing (free demo plan)
  //   ALPHAVANTAGE_API_KEY   – https://www.alphavantage.co/support/#api-key (free)
}
